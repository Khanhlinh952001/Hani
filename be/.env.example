DB_HOST=localhost
POSTGRES_USER=hani
POSTGRES_PASSWORD=your_password
POSTGRES_DB=hani_db
POSTGRES_PORT=5432

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

SONIOX_API_KEY=your_soniox_api_key
TTS_PROVIDER=openai
SONIOX_TTS_MODEL=tts-rt-v1
SONIOX_TTS_LANGUAGE=ko
SONIOX_TTS_VOICE=Kenji
SONIOX_TTS_AUDIO_FORMAT=mp3

JWT_SECRET=change-me-in-production

# Firebase Cloud Messaging
FCM_ENABLED=true
PUSH_CRON_ENABLED=true
PUSH_APP_URL=http://localhost:3000
# Download service account JSON from Firebase Console → Project Settings → Service accounts
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Or single-line JSON only (multiline JSON breaks godotenv):
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
